# ── VisionVault Pure YOLO11s MVP Configuration ───────────────────────────────
# Optimized for laptop CPU performance & high-recall indoor furniture tracking

# ── Directories ───────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
FRAMES_DIR=./frames

# ── Speed vs. Recall Tuning ───────────────────────────────────────────────────
FAST_MODE=false
MAX_FRAMES=10
FRAME_INTERVAL_SEC=3.0
FRAME_QUALITY=80

# ── Model Selection ───────────────────────────────────────────────────────────
# Use YOLO11s as the high-recall default indoor detector
YOLO_WEIGHTS=yolo11s.pt
YOLO_CONF=0.15
TRACK_DETECTION_CONF=0.15
YOLO_INFER_IMGSZ=640
YOLO_INPUT_TARGET_WIDTH=640

# ── Temporal Validation ───────────────────────────────────────────────────────
MIN_PERSIST_FRAMES=1
TEMPORAL_MIN_AVG_CONF=0.12
