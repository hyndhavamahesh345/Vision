# ── Primary: Gemini Vision API (recommended) ─────────────────────────────────
# Get a free key at https://aistudio.google.com/apikey (1500 req/day free)
# Leave blank to use the local YOLO + Florence-2 fallback pipeline
GEMINI_API_KEY=
MODEL=gemini-2.0-flash

# ── Directories ───────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
FRAMES_DIR=./frames

# ── Pipeline ──────────────────────────────────────────────────────────────────
# Gemini key set?  → Gemini Vision (cloud, fast, detects everything)
# No key?          → YOLO + Florence-2 (local, free, no internet needed)
USE_HYBRID=true
USE_FLORENCE=true
FLORENCE_MODEL=microsoft/Florence-2-base

# ── Ollama LLaVA (optional 3rd fallback) ─────────────────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llava

# ── Frame extraction ──────────────────────────────────────────────────────────
MAX_FRAMES=10
FRAME_INTERVAL_SEC=3.0
FRAME_QUALITY=80

# ── Florence-2 gap-fill (used only when Gemini key is absent) ─────────────────
YOLO_GAP_THRESHOLD=4
MAX_FLORENCE_CALLS=4
YOLO_SKIP_FLORENCE_TOTAL=12
MAX_LLAVA_CALLS=0
