# ── Directories ──────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
FRAMES_DIR=./frames

# ── Pipeline selector ────────────────────────────────────────────────────────
# Set USE_HYBRID=true to use YOLO + LLaVA locally (no API key needed)
# Set USE_HYBRID=false to use simulated fallback only
USE_HYBRID=true

# ── YOLO + LLaVA (local, free, no API key) ───────────────────────────────────
# YOLO downloads automatically on first run (yolo11x.pt ~130MB)
# LLaVA requires Ollama running: https://ollama.com  →  ollama pull llava
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llava
# Frames with fewer than this many YOLO detections also get LLaVA gap-fill
YOLO_GAP_THRESHOLD=3

# ── Gemini cloud (optional, overrides hybrid if set) ─────────────────────────
# Leave blank to use the free local hybrid pipeline
GEMINI_API_KEY=
MODEL=gemini-2.0-flash
